{
  "name": "pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "auth:schema:generate": "pnpm dlx @better-auth/cli@latest generate --y --config ./better-auth.config.ts --output ./src/lib/db/schemas/better-auth.schema.ts && prettier --write ./src/lib/db/schemas/better-auth.schema.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc  --noEmit",
    "lint": "next lint",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "db:init:local": "wrangler d1 execute DB --local --env=development --command=\"SELECT 1\"",
    "db:migration:apply:dev": "wrangler d1 migrations apply DB --remote --env=development",
    "db:migration:apply:local": "pnpm run db:init:local && wrangler d1 migrations apply DB --local --env=development",
    "db:migration:apply:prod": "wrangler d1 migrations apply DB --remote --env=production",
    "db:migration:generate": "drizzle-kit generate",
    "db:migration:list:dev": "wrangler d1 migrations list DB --remote --env=development",
    "db:migration:list:local": "wrangler d1 migrations list DB --local --env=development",
    "db:migration:list:prod": "wrangler d1 migrations list DB --remote --env=production",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1",
    "db:studio:local": "pnpm run db:init:local && drizzle-kit studio --port 4001",
    "deploy:dev": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars  --env=development",
    "deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env=production",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts --env=development",
    "seed:admin": "tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tanstack/react-query": "^5.95.2",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.6.0",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "@eslint/eslintrc": "^3",
    "@libsql/client": "^0.17.2",
    "@nerdfolio/drizzle-d1-helpers": "^0.1.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.7.4",
    "wrangler": "^4.77.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}